---
// Driven by MyFolio. Reads ./services.md at the repo root and renders it through the
// site's real components + tokens (same bridge as index.astro / home-demo).
import fs from 'node:fs';
import path from 'node:path';
import Base from '../layouts/Base.astro';
import MyFolioRender from '../components/MyFolioRender.astro';
import { parseContent } from '../lib/parseContent.js';

let md = '';
try { md = fs.readFileSync(path.resolve('./services.md'), 'utf8'); }
catch (e) { md = '# Revenue Architects\n## Services — Revenue Architects\n### Notice\nNo services.md found at the repo root yet.'; }
const { sections } = parseContent(md);
const hasFooter = sections.some((s) => s.type === 'footer');
const hasNav = sections.some((s) => s.type === 'nav');
---
<Base
  title="Services — Revenue Architects"
  description="Three ways to put the method to work: Training, Certification, and Engagement."
  showNav={!hasNav}
  showFooter={!hasFooter}
>
  <MyFolioRender sections={sections} />
</Base>
