---
// Driven by MyFolio. Reads ./contact.md at the repo root and renders it through
// the site's real components + tokens — same bridge as the other pages.
import fs from 'node:fs';
import path from 'node:path';
import Base from '../layouts/Base.astro';
import MyFolioRender from '../components/MyFolioRender.astro';
import { parseContent } from '../lib/parseContent.js';

let md = '';
try { md = fs.readFileSync(path.resolve('./contact.md'), 'utf8'); }
catch (e) { md = '# Revenue Architects\n## Contact\n### Notice\nNo contact.md found at the repo root yet.'; }
const { sections } = parseContent(md);
const hasFooter = sections.some((s) => s.type === 'footer');
const hasNav = sections.some((s) => s.type === 'nav');
---
<Base
  title="Contact — Revenue Architects"
  description="Get in touch with Revenue Architects."
  showNav={!hasNav}
  showFooter={!hasFooter}
>
  <MyFolioRender sections={sections} />
</Base>
