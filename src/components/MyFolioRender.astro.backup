---
// Renders MyFolio sections using this site's real tokens and components.
// The section->HTML mapping lives in the SHARED renderer (src/lib/renderSections.js),
// which the in-app styler/preview also calls, so the preview can never drift from
// what ships here. Content comes from MyFolio; the look is RA's.
import { renderSections } from '../lib/renderSections.js';
const { sections = [] } = Astro.props;
const html = renderSections(sections);
---
<Fragment set:html={html} />
