---
// Two-door call to action. Buttons passed as a `buttons` array:
// [{ href, label, variant: 'orange' | 'outline' | 'teal', external?: boolean }]
const { eyebrow, heading, body, buttons = [] } = Astro.props;

const variantClass = {
  orange: 'bg-orange text-surface hover:bg-orange-600',
  teal: 'bg-teal text-surface hover:bg-teal-600',
  outline: 'border border-navy text-navy hover:bg-navy hover:text-surface',
};
---

<section class="mt-section">
  <div class="mx-auto max-w-content px-6">
    <div class="rounded-card bg-navy px-8 py-12 text-surface md:px-12">
      {eyebrow && <p class="text-sm font-semibold uppercase tracking-wide text-orange-200">{eyebrow}</p>}
      <h2 class="mt-2 max-w-prose text-2xl text-surface md:text-3xl">{heading}</h2>
      {body && <p class="mt-4 max-w-prose text-navy-100">{body}</p>}
      <div class="mt-8 flex flex-col gap-4 sm:flex-row">
        {
          buttons.map((b) => (
            <a
              href={b.href}
              class:list={[
                'inline-flex items-center justify-center rounded-card px-6 py-3 text-sm font-semibold transition-colors',
                variantClass[b.variant] ?? variantClass.orange,
              ]}
              {...(b.external ? { rel: 'noopener', target: '_blank' } : {})}
            >
              {b.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>
