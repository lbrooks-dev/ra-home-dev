---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const {
  title = 'Revenue Architects',
  description = 'Revenue Architects is the practitioner team that created and stewards Revenue Architecture and RAOS — the Revenue Architecture Operating System.',
  showFooter = true,
} = Astro.props;

const fullTitle = title === 'Revenue Architects' ? title : `${title} — Revenue Architects`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://revenuearchitects.com');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Revenue Architects" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
  </head>
  <body class="flex min-h-screen flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-card focus:bg-navy focus:px-4 focus:py-2 focus:text-surface"
    >
      Skip to content
    </a>
    <Nav />
    <main id="main" class="flex-1">
      <slot />
    </main>
    {showFooter && <Footer />}

    <button
      id="to-top"
      type="button"
      aria-label="Back to top"
      class="fixed bottom-6 right-6 z-40 hidden h-11 w-11 items-center justify-center rounded-full border border-navy-100 bg-navy text-surface shadow-lg transition-opacity duration-200 hover:bg-navy-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-orange"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 19V5M5 12l7-7 7 7" />
      </svg>
    </button>

    <script is:inline>
      (function () {
        var btn = document.getElementById('to-top');
        if (!btn) return;
        var shown = false;
        function sync() {
          var show = window.scrollY > 400;
          if (show === shown) return;
          shown = show;
          btn.classList.toggle('hidden', !show);
          btn.classList.toggle('flex', show);
        }
        window.addEventListener('scroll', sync, { passive: true });
        btn.addEventListener('click', function () {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
        sync();
      })();
    </script>
  </body>
</html>
