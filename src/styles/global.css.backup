/* Self-hosted Plus Jakarta Sans (fallback Aptos, system-ui — see tailwind.config.mjs) */
@import '@fontsource/plus-jakarta-sans/400.css';
@import '@fontsource/plus-jakarta-sans/500.css';
@import '@fontsource/plus-jakarta-sans/600.css';
@import '@fontsource/plus-jakarta-sans/700.css';
@import '@fontsource/plus-jakarta-sans/800.css';

@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  html {
    scroll-behavior: smooth;
  }
  body {
    @apply bg-surface font-sans text-ink antialiased;
  }
  h1,
  h2,
  h3,
  h4 {
    @apply font-bold text-navy;
    text-wrap: balance;
  }
  h1 {
    letter-spacing: -0.02em;
  }
}

@layer components {
  /* Section label: short orange rule + teal uppercase text (matches live dev computed) */
  .eyebrow {
    @apply flex items-center gap-3 text-xs font-bold uppercase text-teal-600;
    letter-spacing: 0.18em;
  }
  .eyebrow::before {
    content: '';
    @apply h-px w-8 bg-orange;
  }
  /* Letterspacing: wide tracking, no orange rule */
  .eyebrow-track {
    @apply inline-block text-xs font-bold uppercase text-teal-600;
    letter-spacing: 0.18em;
  }
  /* Default: plain teal label, normal tracking, no rule */
  .eyebrow-plain {
    @apply inline-block text-xs font-semibold uppercase tracking-wide text-teal;
  }
  /* Subtle blueprint grid — navy (#1F3864) at ~4.5% */
  .bg-grid {
    background-image:
      linear-gradient(to right, rgb(31 56 100 / 0.045) 1px, transparent 1px),
      linear-gradient(to bottom, rgb(31 56 100 / 0.045) 1px, transparent 1px);
    background-size: 40px 40px;
  }
}
/* ---- Per-section surface tone: light / neutral / dark ------------------
   Plain CSS (outside @layer) so Tailwind never purges these — the class
   names are built dynamically in the renderer, so its scanner can't see
   them as literals. One class on the section band; dark recolors its
   contents centrally. Every text/background pair is verified WCAG AA
   (>= 4.5:1). Descendant selectors (>= 0,2,0) win over the utilities. */
.tone-light   { background: #FFFFFF; }
.tone-neutral { background: rgb(31 56 100 / 0.05); }
.tone-dark    { background: #1F3864; color: #D7DCE6; }
.tone-dark p, .tone-dark li { color: #D7DCE6; }
.tone-dark h1, .tone-dark h2, .tone-dark h3 { color: #FFFFFF; }
.tone-dark .eyebrow, .tone-dark .eyebrow-track, .tone-dark .eyebrow-plain { color: #E9C3A8; }
.tone-dark .eyebrow::before { background: #D98A66; }
/* Arrow links (the text-orange utility, not solid buttons) per tone */
.tone-light .text-orange, .tone-neutral .text-orange { color: #8F4527; }
.tone-dark .text-orange { color: #EDB08F; }
.tone-dark .hover\:text-orange-600:hover { color: #F2C0A0; }
/* Cards on dark become translucent light panels */
.tone-dark .rounded-card { background: rgb(255 255 255 / 0.06); border-color: rgb(255 255 255 / 0.16); box-shadow: none; }
.tone-dark .rounded-card h3 { color: #FFFFFF; }
.tone-dark .rounded-card .text-ink { color: #D7DCE6; }
.tone-dark .rounded-card .text-teal { color: #7FC6C8; }
/* ---- Text alignment (left default) ---- */
.align-center { text-align: center; }
.align-center .max-w-prose, .align-center .max-w-4xl { margin-left: auto; margin-right: auto; }
.align-center .eyebrow { justify-content: center; }
.align-right { text-align: right; }
.align-right .max-w-prose, .align-right .max-w-4xl { margin-left: auto; }
.align-right .eyebrow { justify-content: flex-end; }
/* ---- Background treatment, layered over the tone color (none default) ---- */
.secbg-grid {
  background-image:
    linear-gradient(to right, rgb(31 56 100 / 0.05) 1px, transparent 1px),
    linear-gradient(to bottom, rgb(31 56 100 / 0.05) 1px, transparent 1px);
  background-size: 40px 40px;
}
.tone-dark.secbg-grid {
  background-image:
    linear-gradient(to right, rgb(255 255 255 / 0.06) 1px, transparent 1px),
    linear-gradient(to bottom, rgb(255 255 255 / 0.06) 1px, transparent 1px);
}
.secbg-gradient { background-image: linear-gradient(180deg, rgb(31 56 100 / 0.06), transparent 70%); }
.tone-dark.secbg-gradient { background-image: linear-gradient(180deg, rgb(255 255 255 / 0.07), transparent 70%); }
/* ---- CTA Banner variants (boxed / full / bar; colors set inline by renderer) ---- */
.cta-section { position: relative; }
.st-style-light { background: #FFFFFF; }
.st-style-neutral { background: #EEF1F6; }
.st-style-dark { background: #17294F; }
.cta-inner { max-width: 1280px; margin: 0 auto; padding: 6rem 1.5rem; }
.cta-box { border-radius: .75rem; padding: 2.5rem 2rem; }
.cta-eyebrow { font-size: .8rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; margin: 0 0 .5rem; }
.cta-h2 { font-size: clamp(1.5rem, 3vw, 1.875rem); font-weight: 800; line-height: 1.15; margin: 0; max-width: 62ch; }
.cta-desc { margin: 1rem 0 0; max-width: 62ch; line-height: 1.6; font-size: 1rem; }
.cta-actions { display: flex; flex-direction: column; gap: 1rem; margin-top: 2rem; }
@media (min-width: 640px) { .cta-actions { flex-direction: row; } }
.cta-btn { display: inline-flex; align-items: center; justify-content: center; border-radius: .6rem; padding: .7rem 1.4rem; font-size: .875rem; font-weight: 700; text-decoration: none; transition: opacity .2s; }
.cta-btn:hover { opacity: .88; }
.cta-link { padding: .2rem 0; border-radius: 0; }
.cta-link:hover { text-decoration: underline; opacity: 1; }
.cta-align-center .cta-box { text-align: center; }
.cta-align-center .cta-h2, .cta-align-center .cta-desc { margin-left: auto; margin-right: auto; }
.cta-align-center .cta-actions { justify-content: center; }
.cta-type-bar .cta-box { display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; flex-wrap: wrap; padding: 1.5rem 2rem; }
.cta-type-bar .cta-textwrap { flex: 1; min-width: 240px; }
.cta-type-bar .cta-h2 { font-size: 1.25rem; }
.cta-type-bar .cta-desc { display: none; }
.cta-type-bar .cta-actions { margin-top: 0; flex-direction: row; }
.cta-align-center.cta-type-bar .cta-box { justify-content: center; }
.cta-align-right .cta-box { text-align: right; }
.cta-align-right .cta-h2, .cta-align-right .cta-desc { margin-left: auto; margin-right: 0; }
.cta-align-right .cta-actions { justify-content: flex-end; }
.cta-align-right.cta-type-bar .cta-box { justify-content: flex-end; }
.cta-fullinner { max-width: 1280px; margin: 0 auto; padding: 5rem 1.5rem; }
.cta-name-full.cta-align-center .cta-fullinner { text-align: center; }
.cta-name-full .cta-h2 { font-size: clamp(1.6rem, 3.4vw, 2.1rem); font-weight: 800; line-height: 1.12; margin: 0; }
.cta-name-full .cta-desc { margin: .85rem 0 0; font-size: 1.05rem; line-height: 1.55; }
.cta-name-full.cta-align-center .cta-h2 { max-width: 26ch; margin-left: auto; margin-right: auto; }
.cta-name-full.cta-align-center .cta-desc { max-width: 60ch; margin-left: auto; margin-right: auto; }
.cta-name-full .cta-actions { display: flex; flex-direction: row; gap: 1rem; margin-top: 2rem; }
.cta-name-full.cta-align-center .cta-actions { justify-content: center; }
.cta-name-full.cta-align-right .cta-fullinner { text-align: right; }
.cta-name-full.cta-align-right .cta-h2, .cta-name-full.cta-align-right .cta-desc { margin-left: auto; margin-right: 0; }
.cta-name-full.cta-align-right .cta-actions { justify-content: flex-end; }
/* ---- Hero rotating logo watermark (option: herologo) ---- */
.ra-herologo { position: absolute; right: -6%; top: 50%; transform: translateY(-50%); width: min(58vw, 620px); opacity: 0.15; pointer-events: none; z-index: 0; }
.ra-herologo img { display: block; width: 100%; height: auto; transform-origin: 50% 50%; animation: ra-spin 90s linear infinite; }
@keyframes ra-spin { to { transform: rotate(360deg); } }
@media (prefers-reduced-motion: reduce) { .ra-herologo img { animation: none; } }
/* ---- Boxed client logos (option: clientstyle=boxed; first logo filled) ---- */
.ra-logobox { display: flex; align-items: center; justify-content: center; aspect-ratio: 1 / 1; background: #FFFFFF; border-radius: 15px; padding: 1.25rem; border: 5px solid transparent; box-shadow: 0 1px 3px rgb(31 56 100 / 0.06); filter: grayscale(1); opacity: 0.72; transition: filter 0.2s, opacity 0.2s, box-shadow 0.2s, border-color 0.2s; }
.ra-logobox img { display: block; height: 48px; width: auto; max-width: 100%; object-fit: contain; }
.ra-logobox:hover { filter: grayscale(0); opacity: 1; border-color: rgb(31 56 100 / 0.12); box-shadow: 0 12px 28px rgb(31 56 100 / 0.16); }
/* ---- Author cards (pageintro split layout, images right) ---- */
.ra-authorcard { margin: 0; }
.ra-authorcard img { display: block; width: 100%; aspect-ratio: 1 / 1; object-fit: cover; border-radius: 14px; box-shadow: 0 8px 24px rgb(31 56 100 / 0.12); }
.ra-authorcard figcaption { margin-top: 0.5rem; font-size: 0.8rem; font-weight: 600; color: #1F3864; }
/* Collapse the gap between a CTA section and a content footer that follows it */
div:has(> .cta-section):has(+ div > footer) .cta-inner,
div:has(> .cta-section):has(+ div > footer) .cta-fullinner { padding-bottom: 1.5rem; }
